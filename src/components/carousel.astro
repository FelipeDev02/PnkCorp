<div id="mainCarousel" class="carousel slide custom-carousel shadow-lg" data-bs-ride="carousel">
    <div class="carousel-inner rounded-4 border border-white border-opacity-10" id="carousel-items-wrapper">
        <div class="carousel-item active">
            <div class="d-flex justify-content-center align-items-center" style="height: 450px; background: rgba(255,255,255,0.02);">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<script>
    async function fetchCarousel() {
        const wrapper = document.getElementById('carousel-items-wrapper');

        try {
            const response = await fetch('/api/carrusel/');
            const items = await response.json();

            if (items && items.length > 0) {
                wrapper.innerHTML = items.map((item, index) => {
                    const imageSource = item.image.startsWith('http')
                        ? item.image
                        : item.image;

                    return `
                        <div class="carousel-item ${index === 0 ? 'active' : ''}">
                            <img src="${imageSource}" class="d-block w-100" alt="${item.title}">
                            <div class="carousel-overlay">
                                <h3>${item.title}</h3>
                                <p>${item.description}</p>
                            </div>
                        </div>
                    `;
                }).join('');
            } else {
                wrapper.innerHTML = '<div class="p-5 text-center text-muted">No hay proyectos en la BD.</div>';
            }
        } catch (error) {
            console.error("Error cargando carrusel:", error);
            wrapper.innerHTML = '<div class="p-5 text-center text-danger">Error de conexión con Django.</div>';
        }
    }

    fetchCarousel();
</script>

<style>
    .custom-carousel {
        max-width: 900px;
        margin: 0 auto;
    }
    .carousel-item img {
        height: 450px;
        object-fit: cover;
        filter: brightness(0.6);
    }
    .carousel-overlay {
        position: absolute;
        bottom: 40px;
        left: 40px;
        z-index: 10;
        text-align: left;
        font-family: 'Syne', sans-serif;
    }
    .carousel-overlay h3 {
        font-weight: 800;
        color: #7b8bff;
        margin-bottom: 5px;
    }
    .carousel-overlay p {
        color: white;
        margin-bottom: 0;
    }

    @media (max-width: 768px) {
        .carousel-item img { height: 300px; }
        .carousel-overlay { bottom: 20px; left: 20px; }
    }
</style>

---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="nav-inner">
            <a href="/" class="nav-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                </div>
                <span class="logo-name">PnK<span>Corp</span></span>
            </a>

            <div id="nav-user-actions" class="d-none">
                <span id="nav-username" class="me-3 d-none d-md-inline-block text-muted small fw-medium"></span>
                <button id="layoutLogoutBtn" class="btn-logout-minimal" title="Cerrar sesión">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    <span>Salir</span>
                </button>
            </div>
        </div>
    </nav>

    <main class="page">
        <slot />
    </main>

    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Lógica de Gestión de Sesión en el Cliente
        document.addEventListener('DOMContentLoaded', () => {
            const user = localStorage.getItem('user');
            const actionsDiv = document.getElementById('nav-user-actions');
            const usernameSpan = document.getElementById('nav-username');
            const logoutBtn = document.getElementById('layoutLogoutBtn');

            // 1. Mostrar acciones solo si hay un usuario logueado
            if (user && actionsDiv) {
                actionsDiv.classList.remove('d-none');
                actionsDiv.classList.add('d-flex', 'align-items-center');
                if (usernameSpan) usernameSpan.innerText = user;
            }

            // 2. Manejo del Logout
            logoutBtn?.addEventListener('click', async () => {
                try {
                    // Notificar al servidor Django
                    await fetch('/api/logout/', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                } catch (e) {
                    console.warn("Cerrando sesión localmente...");
                } finally {
                    localStorage.clear();
                    window.location.href = '/';
                }
            });
        });
    </script>
</body>
</html>

<style is:global>
    /* VARIABLES DE DISEÑO PNK */
    :root {
        --bg-deep: #0a0c14;
        --bg-mid: #111422;
        --accent: #5c6ef8;
        --accent-glow: #7b8bff;
        --surface: rgba(255, 255, 255, 0.05);
        --border: rgba(255, 255, 255, 0.09);
        --text: #e8eaf4;
        --text-muted: #7b80a0;
        --nav-h: 70px;
        --danger: #ff4d4d;
    }

    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg-deep);
        color: var(--text);
        overflow-x: hidden;
        min-height: 100vh;
    }

    /* FONDO DINÁMICO */
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
            radial-gradient(ellipse 70% 60% at 20% 30%, rgba(92, 110, 248, .2) 0%, transparent 70%),
            radial-gradient(ellipse 50% 50% at 80% 80%, rgba(123, 139, 255, .12) 0%, transparent 60%);
        z-index: -1;
        animation: bgShift 15s ease-in-out infinite alternate;
    }

    @keyframes bgShift {
        from { opacity: 0.7; transform: scale(1); }
        to { opacity: 1; transform: scale(1.05); }
    }

    /* GRILLA DE PUNTOS */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255, 255, 255, .05) 1px, transparent 1px);
        background-size: 32px 32px;
        z-index: -1;
        pointer-events: none;
    }

    /* NAVEGACIÓN PRINCIPAL */
    nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--nav-h);
        background: rgba(10, 12, 20, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        z-index: 1000;
        display: flex;
        align-items: center;
    }

    .nav-inner {
        width: 100%;
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 32px;
        display: flex;
        justify-content: space-between; /* SEPARACIÓN LOGO - BOTÓN */
        align-items: center;
    }

    .nav-logo { 
        display: flex; 
        align-items: center; 
        gap: 14px; 
        text-decoration: none; 
        transition: opacity 0.2s;
    }
    
    .nav-logo:hover { opacity: 0.8; }

    .logo-icon {
        width: 38px; height: 38px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
        border-radius: 10px;
        display: grid; place-items: center;
        box-shadow: 0 0 20px rgba(92, 110, 248, .3);
    }

    .logo-name { font-family: 'Syne', sans-serif; font-weight: 800; color: white; font-size: 20px; letter-spacing: -0.5px; }
    .logo-name span { color: var(--accent-glow); }

    /* BOTÓN SALIR */
    .btn-logout-minimal {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .btn-logout-minimal:hover {
        background: rgba(255, 77, 77, 0.12);
        border-color: rgba(255, 77, 77, 0.4);
        color: var(--danger);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(255, 77, 77, 0.1);
    }

    /* ESTRUCTURA DE PÁGINA */
    .page {
        min-height: 100vh;
        padding-top: calc(var(--nav-h) + 20px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Scrollbar Estilizada */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-deep); }
    ::-webkit-scrollbar-thumb { background: var(--surface); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--border); }
</style>
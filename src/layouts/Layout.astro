---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav>
        <a href="/" class="nav-logo">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
            </div>
            <span class="logo-name">PnK<span>Corp</span></span>
        </a>
    </nav>

    <main class="page">
        <slot />
    </main>

    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<style is:global>
    /* PEGADO DIRECTO DE TU LOGIN.CSS (Variables y Estructura Base) */
    :root {
        --bg-deep: #0a0c14;
        --bg-mid: #111422;
        --accent: #5c6ef8;
        --accent-glow: #7b8bff;
        --surface: rgba(255, 255, 255, 0.05);
        --border: rgba(255, 255, 255, 0.09);
        --text: #e8eaf4;
        --text-muted: #7b80a0;
        --nav-h: 64px;
    }

    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg-deep);
        color: var(--text);
        overflow-x: hidden;
        min-height: 100vh;
    }

    /* FONDO ANIMADO DE FELIPE */
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
            radial-gradient(ellipse 70% 60% at 20% 30%, rgba(92, 110, 248, .22) 0%, transparent 65%),
            radial-gradient(ellipse 55% 50% at 80% 75%, rgba(123, 139, 255, .14) 0%, transparent 60%),
            radial-gradient(ellipse 40% 40% at 55% 10%, rgba(92, 110, 248, .10) 0%, transparent 55%);
        z-index: -1;
        animation: bgShift 12s ease-in-out infinite alternate;
    }

    @keyframes bgShift {
        from { opacity: .8; transform: scale(1); }
        to { opacity: 1; transform: scale(1.04); }
    }

    /* Grilla de puntos */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255, 255, 255, .06) 1px, transparent 1px);
        background-size: 32px 32px;
        z-index: -1;
        pointer-events: none;
    }

    /* NAVBAR ESTILO PNK */
    nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--nav-h);
        display: flex;
        align-items: center;
        padding: 0 32px;
        background: rgba(10, 12, 20, .55);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border);
        z-index: 100;
    }

    .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-glow) 100%);
        border-radius: 10px;
        display: grid; place-items: center;
        box-shadow: 0 0 18px rgba(92, 110, 248, .45);
    }
    .logo-name { font-family: 'Syne', sans-serif; font-weight: 800; color: var(--text); font-size: 18px; }
    .logo-name span { color: var(--accent-glow); }

    .page {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        padding-top: var(--nav-h);
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>